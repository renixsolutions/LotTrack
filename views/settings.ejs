<%- include('partials/header') %>
<%- include('partials/sidebar', { activePage: 'settings' }) %>

<main class="main">
  <header class="topbar">
    <div class="topbar-left">
      <div class="topbar-title">Account Settings</div>
    </div>
  </header>

  <div class="page-content">
    <div style="max-width: 800px; margin: 0 auto;">
      
      <!-- PROFILE SECTION -->
      <div class="card">
        <div class="card-header">
          <div class="card-title"><i class="fas fa-user-circle mr-8"></i> Personal Profile</div>
        </div>
        <div class="card-body">
          <div style="display: flex; align-items: center; gap: 24px; margin-bottom: 32px; padding: 20px; background: var(--surface2); border-radius: 16px;">
            <div class="avatar" style="width: 80px; height: 80px; font-size: 24px;">
                <%= user.full_name.split(' ').map(n => n[0]).join('').toUpperCase() %>
            </div>
            <div>
                <h2 style="font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 800;"><%= user.full_name %></h2>
                <p style="color: var(--text3); font-size: 13px; margin-bottom: 8px;"><%= user.role.replace('_', ' ').toUpperCase() %></p>
                <span class="badge badge-received">Active Account</span>
            </div>
          </div>

          <form action="#" onsubmit="event.preventDefault(); showToast('Profile updates are disabled in this demo', 'info')">
            <div class="stats-grid" style="grid-template-columns: 1fr 1fr; margin-bottom: 0;">
                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <input type="text" class="form-input" value="<%= user.full_name %>">
                </div>
                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input type="email" class="form-input" value="<%= user.email %>" readonly style="background: var(--surface2); cursor: not-allowed;">
                </div>
                <div class="form-group">
                    <label class="form-label">Phone Number</label>
                    <input type="text" class="form-input" value="<%= user.phone || '+91 9876543210' %>">
                </div>
                <div class="form-group">
                    <label class="form-label">Language</label>
                    <select class="form-select">
                        <option>English (US)</option>
                        <option>Hindi (Localized)</option>
                    </select>
                </div>
            </div>
            <div style="text-align: right; margin-top: 20px;">
                <button type="submit" class="btn btn-primary">Save Profile Changes</button>
            </div>
          </form>
        </div>
      </div>

      <!-- SECURITY SECTION -->
      <div class="card" style="margin-top: 24px;">
        <div class="card-header">
          <div class="card-title"><i class="fas fa-shield-halved mr-8"></i> Security & Password</div>
        </div>
        <div class="card-body">
            <p style="color: var(--text2); font-size: 13px; margin-bottom: 20px;">Update your password regularly to keep your warehouse data secure.</p>
            <div class="stats-grid" style="grid-template-columns: 1fr 1fr; margin-bottom: 0;">
                <div class="form-group">
                    <label class="form-label">Current Password</label>
                    <input type="password" class="form-input" placeholder="••••••••">
                </div>
                <div class="form-group">
                    <label class="form-label">New Password</label>
                    <input type="password" class="form-input" placeholder="Enter new password">
                </div>
            </div>
            <div style="text-align: right; margin-top: 20px;">
                <button class="btn btn-outline" onclick="showToast('Security settings updated', 'success')">Update Password</button>
            </div>
        </div>
      </div>

      <!-- SYSTEM INFO -->
      <div class="card" style="margin-top: 24px; border: 1.5px dashed var(--border); background: transparent; box-shadow: none;">
        <div class="card-body" style="text-align: center; padding: 32px;">
            <div style="font-size: 11px; font-weight: 700; color: var(--text3); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 8px;">System Version</div>
            <div style="font-family: 'Syne', sans-serif; font-weight: 800; color: var(--accent);">LOTTRACK V2.4.0-STABLE</div>
            <div style="font-size: 12px; color: var(--text3); margin-top: 4px;">Connected to Render Production Node</div>
        </div>
      </div>

    </div>
  </div>
</main>

<style>
    .mr-8 { margin-right: 8px; }
</style>

<%- include('partials/logout_modal') %>
</body>
</html>
