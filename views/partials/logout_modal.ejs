<!-- LOGOUT CONFIRMATION MODAL -->
<div class="overlay" id="logoutModal">
    <div class="modal" style="max-width: 400px; text-align: center;">
        <div class="modal-body" style="padding: 40px 24px;">
            <div style="width: 64px; height: 64px; background: var(--orange-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; color: var(--orange);">
                <i class="fas fa-power-off" style="font-size: 28px;"></i>
            </div>
            <h2 style="font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 800; color: var(--text); margin-bottom: 12px;">Confirm Logout?</h2>
            <p style="color: var(--text3); font-size: 14px; line-height: 1.5; margin-bottom: 32px;">Are you sure you want to exit your session? You will need to login again to manage warehouse shipments.</p>
            
            <div style="display: flex; flex-direction: column; gap: 12px;">
                <button class="btn btn-primary" onclick="closeModal('logoutModal')" style="height: 48px; justify-content: center; width: 100%; border-radius: 12px;">
                    Stay Logged In
                </button>
                <a href="/auth/logout" class="btn btn-outline" style="height: 48px; justify-content: center; width: 100%; border-radius: 12px; color: var(--orange); border-color: var(--orange-light);">
                    Exit Session
                </a>
            </div>
        </div>
    </div>
</div>
