<%- include('partials/header', { pageTitle: 'Shipment Details' }) %>
<%- include('partials/sidebar', { activePage: 'lots' }) %>

<main class="main">
  <header class="topbar">
    <div class="flex gap-8">
      <div class="topbar-title">Lot ID: #<%= lot.id.substring(0, 8) %></div>
    </div>
    <div class="topbar-right">
      <a href="/lot/<%= lot.id %>" target="_blank" class="btn btn-outline">
        <i class="fas fa-qrcode"></i> Public View
      </a>
    </div>
  </header>

  <div class="page-content">
    <!-- LOT INFO CARDS -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon" style="background:var(--accent-light)">
            <i class="fas fa-truck-ramp-box" style="color:var(--accent)"></i>
        </div>
        <div class="stat-label">Destination</div>
        <div class="stat-value" style="color:var(--accent); font-size: 16px;"><%= shop.full_name %></div>
        <div class="stat-sub"><%= shop.email %></div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background:var(--blue-light)">
            <i class="fas fa-circle-info" style="color:var(--blue)"></i>
        </div>
        <div class="stat-label">Current Status</div>
        <div class="stat-value" style="color:var(--blue); font-size: 16px;">
            <span class="badge badge-<%= lot.status.toLowerCase() %>"><%= lot.status %></span>
        </div>
        <div class="stat-sub">Updated <%= new Date(lot.updated_at || lot.created_at).toLocaleDateString() %></div>
      </div>
    </div>

    <!-- ITEM LIST -->
    <div class="card" style="margin-top: 24px;">
      <div class="card-header">
        <div class="card-title">Manifest (<%= items.length %> Items)</div>
      </div>

      <!-- DESKTOP VIEW -->
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Item Name</th>
              <th style="text-align: right;">Quantity</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach(item => { %>
              <tr>
                <td class="fw-600"><%= item.item_name %></td>
                <td style="text-align: right; font-weight: 800; color: var(--accent);">×<%= item.quantity %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- MOBILE VIEW (CARD STACKS) -->
      <div class="mobile-card-list">
        <% items.forEach(item => { %>
          <div class="mobile-card" style="display: flex; justify-content: space-between; align-items: center; padding: 12px 16px;">
            <div>
                <div class="mob-card-label">Item Name</div>
                <div class="fw-700" style="font-size: 15px;"><%= item.item_name %></div>
            </div>
            <div style="text-align: right;">
                <div class="mob-card-label">Quantity</div>
                <div class="fw-800" style="font-size: 16px; color: var(--accent);">×<%= item.quantity %></div>
            </div>
          </div>
        <% }); %>
      </div>

      <% if (items.length === 0) { %>
        <div class="empty-state">No items found in this lot.</div>
      <% } %>
    </div>

    <!-- ACTIONS -->
    <div class="card" style="margin-top: 24px; padding: 24px; text-align: center;">
        <div class="card-title" style="margin-bottom: 16px;">Warehouse Controls</div>
        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
            <% if (lot.status === 'PACKED' && (user.role === 'owner' || user.role === 'staff')) { %>
                <form action="/lots/dispatch/<%= lot.id %>" method="POST">
                    <button type="submit" class="btn btn-primary" style="height: 48px; padding: 0 32px;">
                        <i class="fas fa-truck-fast"></i> Mark as Dispatched
                    </button>
                </form>
            <% } %>
            <button class="btn btn-outline" style="height: 48px; padding: 0 32px;" onclick="openModal('qrPrintModal')">
                <i class="fas fa-qrcode"></i> View & Print Label
            </button>
        </div>
    </div>
  </div>
<!-- PRINT QR MODAL -->
<div class="overlay" id="qrPrintModal">
    <div class="modal" style="max-width: 400px; text-align: center;">
        <div class="modal-header">
            <div class="modal-title">Shipment Label</div>
            <button class="modal-close" onclick="closeModal('qrPrintModal')">×</button>
        </div>
        <div class="modal-body print-area">
            <h2 style="font-family: 'Syne', sans-serif; margin-bottom: 5px;">LotTrack</h2>
            <div style="font-size: 11px; font-weight: 700; color: var(--text3); margin-bottom: 15px; text-transform: uppercase;">Premium Warehouse Logistics</div>
            
            <div style="background: white; padding: 20px; border: 2px solid var(--border); border-radius: 16px; display: inline-block; margin-bottom: 15px;">
                <img src="<%= qrCode %>" alt="QR Code" style="width: 250px; height: 250px; display: block;">
            </div>

            <div style="font-family: monospace; font-size: 14px; font-weight: 800; color: var(--accent); margin-bottom: 4px;">#<%= lot.id.substring(0, 16) %></div>
            <div style="font-size: 13px; font-weight: 700;">TO: <%= shop.full_name %></div>
            <div style="font-size: 11px; color: var(--text3); margin-top: 4px;"><%= new Date(lot.created_at).toLocaleDateString() %></div>
        </div>
        <div class="modal-footer" style="justify-content: center;">
            <button class="btn btn-primary" onclick="window.print()" style="width: 100%;">
                <i class="fas fa-print"></i> Print Now
            </button>
        </div>
    </div>
</div>
</body>
</html>
